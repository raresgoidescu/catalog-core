#!/bin/sh

if test ! -f "workdir/build/sqlite_fc-x86_64"; then
    echo "No kernel file workdir/build/sqlite_fc-x86_64." 1>&2
    echo "Did you run ./scripts/build/fc.x86_64 ?" 1>&2
    exit 1
fi

# Pack filesystem as an initial ramdisk CPIO file.
rm -f rootfs.cpio
./workdir/unikraft/support/scripts/mkcpio rootfs.cpio ./rootfs/

rm -f firecracker.socket

firecracker-x86_64 \
    --api-sock firecracker.socket \
    --config-file fc.x86_64.json
