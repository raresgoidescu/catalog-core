#!/bin/sh

if test ! -f "workdir/build/sqlite_fc-arm64"; then
    echo "No kernel file workdir/build/sqlite_fc-arm64." 1>&2
    echo "Did you run ./scripts/build/fc.arm64 ?" 1>&2
    exit 1
fi

rm -f rootfs.cpio
./workdir/unikraft/support/scripts/mkcpio rootfs.cpio ./rootfs/

rm -f firecracker.socket

firecracker-aarch64 \
        --api-sock firecracker.socket \
        --config-file fc.arm64.json
