#!/bin/sh

if test ! -f "workdir/build/sqlite_xen-x86_64"; then
    echo "No kernel file workdir/build/sqlite_xen-x86_64." 1>&2
    echo "Did you run ./scripts/build/xen.x86_64 ?" 1>&2
    exit 1
fi

rm -f rootfs.cpio
./workdir/unikraft/support/scripts/mkcpio rootfs.cpio ./rootfs/

xl create -c xen.x86_64.cfg